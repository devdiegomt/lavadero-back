{
  "compilerOptions": {
    // ── Target ──────────────────────────────────────────────────────────────
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",

    // ── Output ──────────────────────────────────────────────────────────────
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,

    // ── Strict ──────────────────────────────────────────────────────────────
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    // ── Interop ──────────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    // ── JS sidecars que quedan en JS ─────────────────────────────────────────
    // Únicos JS en el bundle de producción:
    //   - src/modules/billing/alegra.client.js
    //   - src/modules/billing/billing.sync.js
    // (Migrarlos a TS es un proyecto aparte porque dependen del SDK de Alegra)
    "allowJs": true,
    "checkJs": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "bot-wa",
    "__tests__",
    // Scripts de admin: viven en JS, se ejecutan con `node src/shared/db/xxx.js`.
    // No entran al build del servidor.
    "src/shared/db/migrate*.js",
    "src/shared/db/seed*.js",
    "src/shared/db/demo-seed.js",
    "src/shared/db/encrypt-value.js",
    "src/shared/db/rotate-encryption-key.js"
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}