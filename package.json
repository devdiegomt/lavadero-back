{
  "name": "carwash-saas-backend",
  "version": "1.0.0",
  "description": "SaaS para lavaderos de autos - Backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:migrate": "node src/shared/db/migrate.js",
    "db:migrate-billing": "node src/shared/db/migrate-billing.js",
    "db:migrate-mt": "node src/shared/db/migrate-multitenant.js",
    "db:seed-superadmin": "node src/shared/db/seed-superadmin.js",
    "db:seed": "node src/shared/db/seed.js",
    "db:reset": "npm run db:migrate-all && npm run db:seed",
    "db:demo": "node src/shared/db/seed.js && node src/shared/db/demo-seed.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch --detectOpenHandles",
    "db:migrate-all": "node src/shared/db/migrate.js && node src/shared/db/migrate-billing.js && node src/shared/db/migrate-multitenant.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.12.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testTimeout": 15000,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}