# =============================================================================
# Carwash SaaS - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores

# Server
PORT=3000
NODE_ENV=development            # development | production
LOG_LEVEL=debug                 # debug | info | warn | error (Pino)

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carwash_dev

# Redis (sesiones WhatsApp)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=cambia-esto-por-un-string-largo-y-random-de-64-chars-minimo
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis (para sesiones WhatsApp)
REDIS_URL=redis://localhost:6379

# WhatsApp - Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token

# WhatsApp - 360dialog (alternativa a Twilio)
DIALOG360_API_KEY=your_api_key

# WhatsApp Webhook
WHATSAPP_VERIFY_TOKEN=your_random_verify_token

# Super Admin
SUPER_ADMIN_EMAIL=superadmin@carwash-saas.com
SUPER_ADMIN_PASSWORD=super123!

# Sentry (opcional, monitoreo de errores)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# =============================================================================
# NOTAS:
# - Facturación Alegra: se configura POR TENANT en la BD (billing_api_key)
# - WhatsApp: credenciales globales aquí, config por tenant en BD
# - Planes/límites: se configuran en tabla plans (Fase 5)
# =============================================================================
