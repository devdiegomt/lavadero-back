# =============================================================================
# Carwash SaaS - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores

# Server
PORT=3000
NODE_ENV=development            # development | production
LOG_LEVEL=debug                 # debug | info | warn | error (Pino)

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carwash_dev

# Redis (cache, sesiones)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=cambia-esto-por-un-string-largo-y-random-de-64-chars-minimo
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cifrado de datos sensibles (billing_api_key, etc.)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: una vez cifrados los datos, perder esta clave significa perder
# acceso a las credenciales guardadas. Guárdala en un manager de secretos.
ENCRYPTION_KEY=4b6cddbd404c3c34fab317fc3f13d7c2e62c35c3cde62d408f4cc6b0a7fc7066

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Super Admin
SUPER_ADMIN_EMAIL=superadmin@carwash-saas.com
SUPER_ADMIN_PASSWORD=super123!

# =============================================================================
# WhatsApp AI (Arquitectura Baileys + n8n + Claude)
# =============================================================================

# Número de WhatsApp del lavadero (con prefijo +, ej: +573001234567)
# Usado por bot-wa para identificarse y por n8n para resolver el tenant
TENANT_PHONE=+573001234567

# Clave secreta compartida entre n8n y el backend
# n8n la envía como header: x-api-key: <N8N_API_KEY>
N8N_API_KEY=genera-un-string-random-seguro-aqui

# Claude API Key (Anthropic) — usada en n8n como variable de entorno
# N8n la expone en expresiones como: {{ $env.ANTHROPIC_API_KEY }}
ANTHROPIC_API_KEY=sk-ant-api03-...

# Token opcional para que bot-wa autentique llamadas a n8n
# Si se deja vacío, bot-wa no envía Authorization header
N8N_AUTH_TOKEN=

# Intervalo de reconexion del bot en ms (default: 5000)
RECONNECT_INTERVAL_MS=5000

# =============================================================================
# n8n (solo Docker Compose)
# =============================================================================

# Credenciales para la UI de n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=carwash2024!

# Base de datos de n8n (separada del carwash, mismo Postgres)
N8N_DB=n8n

# URL pública de n8n (para webhooks desde WhatsApp/Baileys)
# En desarrollo: http://localhost:5678/
# En producción: https://n8n.tu-dominio.com/
N8N_WEBHOOK_URL_PUBLIC=http://localhost:5678/
N8N_HOST=localhost
N8N_PROTOCOL=http

# =============================================================================
# PostgreSQL Docker Compose
# =============================================================================
POSTGRES_DB=carwash_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Zona horaria
TIMEZONE=America/Bogota

# Sentry (opcional, monitoreo de errores)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# =============================================================================
# NOTAS:
# - Facturación Alegra: se configura POR TENANT en la BD (billing_api_key)
# - WhatsApp: bot-wa corre como proceso separado (ver /bot-wa)
# - n8n: importar workflow desde /n8n/workflows/whatsapp-main.json
# - Para ver el QR de WhatsApp: docker compose logs -f bot-wa
# =============================================================================
